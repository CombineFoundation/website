rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Secure donations rules: allow anyone to submit donations, but restrict read/edit/delete
    match /donations/{donationId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Secure messages rules: allow anyone to send messages, but restrict read/edit/delete
    match /messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Programs rules: public read-write for seeding and displaying
    match /programs/{programId} {
      allow read, write: if true;
    }

    // Applications rules: public read-write for seeding and displaying
    match /applications/{applicationId} {
      allow read, write: if true;
    }
  }
}
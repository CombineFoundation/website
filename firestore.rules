rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Read access is allowed for anyone to public website collections.
    // Writes are only allowed for authenticated users / admin.
    match /team_members/{document} {
      allow read: if true;
      allow write: if true; // In production, restrict to admins
    }
    match /annual_reports/{document} {
      allow read: if true;
      allow write: if true; // In production, restrict to admins
    }
    match /mous/{document} {
      allow read: if true;
      allow write: if true; // In production, restrict to admins
    }
    match /certificates/{document} {
      allow read: if true;
      allow write: if true; // In production, restrict to admins
    }
    match /programs/{document} {
      allow read: if true;
      allow write: if true; // In production, restrict to admins
    }

    // Contact form submissions
    match /messages/{document} {
      allow create: if true;
      allow read, write: if true; // In production, restrict to admins
    }

    // Program applications
    match /applications/{document} {
      allow create: if true;
      allow read, write: if true; // In production, restrict to admins
    }

    // Default catch-all rule
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2027, 12, 31);
    }
  }
}
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Events: public read, admin write
    match /events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Courses: public read, admin write
    match /courses/{courseId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Blogs: public read, admin write
    match /blogs/{blogId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Projects: public read, admin write
    match /projects/{projectId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Contacts: public create, admin read/write
    match /contacts/{contactId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Donations: public create, admin read/write
    match /donations/{donationId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Messages: allow anyone to send, admin can read/delete
    match /messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Programs: public read-write for seeding and displaying
    match /programs/{programId} {
      allow read, write: if true;
    }

    // Applications: public read-write for seeding and displaying
    match /applications/{applicationId} {
      allow read, write: if true;
    }

    // Jobs: public read-write for seeding and displaying
    match /jobs/{jobId} {
      allow read, write: if true;
    }

    // Splash Banners: public read, admin write
    match /splashBanners/{bannerId} {
      allow read: if true;
      allow write: if request.auth != null;
    // MOUs: public read, admin write
    match /mous/{mouId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Annual Reports: public read, admin write
    match /annualReports/{reportId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Team Members: public read, admin write
    match /teamMembers/{memberId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Partners: public read, admin write
    match /partners/{partnerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Splash Banners: public read, admin write
    match /splashBanners/{bannerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}